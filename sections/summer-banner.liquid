<style>
.sunmmer-banner{
  position: relative;
}
.sunmmer-banner::before{
  position: absolute;
  content: '';
  display: block;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.1);
  z-index: 3;
}
.sunmmer-banner .img{
  position: relative;
  z-index: 1;
  width: 100%;
  display: block;
}

.sunmmer-banner .mb-box{
  display: none;
}

.sunmmer-banner .sunmmer-banner-text{
  position: absolute;
  width: 100%;
  left: 0;
  bottom: 65px;
  z-index: 4;
}

.sunmmer-banner .container{
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 30px;
}

.sunmmer-banner .sunmmer-banner-text-left{
  max-width: 770px;
  color: #fff;
}

.sunmmer-banner .sunmmer-banner-tag{
  color: #FBFAF4;
  font-size: 16px;
  font-family: var(--heading-font-family);
  line-height: 1.5;
  display: inline-block;
  background: #E0004D;
  padding: 3px 17px;
  overflow: hidden;
  position: relative;
  border-radius: 30px;
}

.sunmmer-banner .sunmmer-banner-tag::before {
  position: absolute;
  content: "";
  display: block;
  width: 200%;
  height: 200%;
  z-index: 2;
  background: linear-gradient(
    -45deg,
    rgba(255, 255, 255, 0) 40%,
    rgba(255, 255, 255, 0.5) 50%,
    rgba(255, 255, 255, 0) 60%
  );
  animation: scanning 3s linear infinite;
}
@keyframes scanning {
  0% {
    transform: translate(-100%, -100%);
  }
  100% {
    transform: translate(100%, 100%);
  }
}

.sunmmer-banner .sunmmer-banner-sub{
  font-size: 24px;
  line-height: 1.5;
  letter-spacing: 0.24px;
  margin-top: 18px;
}

.sunmmer-banner .sunmmer-banner-title{
  font-size: 80px;
  line-height: 1;
  letter-spacing: 0.8px;
  margin-top: 18px;
}

.sunmmer-banner .sunmmer-banner-p{
  color: #190A0A;
  font-size: 60px;
  line-height: 1.2;
  letter-spacing: 0.6px;
}

.sunmmer-banner .sunmmer-banner-btn{
  width: 362px;
  height: 97px;
  border-radius: 97px;
  cursor: pointer;
  border: 1.33px solid rgba(255, 255, 255, 0.30);
  display:flex;
  align-items: center;
  justify-content: center;
  position: relative;
  background: rgba(255, 255, 255, 0.20);
  backdrop-filter: blur(13px);
  -webkit-backdrop-filter: blur(13px);
  padding-right: 35px;
}

.sunmmer-banner .sunmmer-banner-btn .img{
  position: absolute;
  width: 45px;
  right: 30px;
  bottom: 20px;
}

.sunmmer-banner .sunmmer-banner-t{
  color: #FFFFFC;
  font-size: 18px;
  line-height: 1.5;
  font-family: var(--heading-font-family);
}

.sunmmer-banner .sunmmer-banner-p{
  color: #FFFFFC;
  font-size: 16px;
  line-height: 1.5;
  display: flex;
  align-items: center;
  gap: 24px;
}

.sunmmer-banner .sunmmer-banner-p span{
  color: #A4F1F4;
  font-size: 16px;
  line-height: 1.5;
}

@media (max-width:991px) {
  .sunmmer-banner .sunmmer-banner-sub{
    font-size: 14px;
    color: #fff;
    line-height: 1.5;
    margin-top: 5px;
  }
  .sunmmer-banner .sunmmer-banner-title{
    font-size: 28px;
    color: #fff;
    line-height: 1.2;
    margin-top: 11px;
    font-family: var(--heading-font-family);
  }
  .sunmmer-banner .mb-box{
    display: block;
  }
  .sunmmer-banner .pc-box{
    display: none;
  }
  .sunmmer-banner .container{
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    height: 100%;
  }
  .sunmmer-banner .sunmmer-banner-text-left{
    text-align: center;
  }
  .sunmmer-banner .sunmmer-banner-text{
    bottom: 0;
    height: 100%;
    padding: 38px 0 48px 0;
  }
  .sunmmer-banner .sunmmer-banner-text-right{
    width: 100%;
  }
  .sunmmer-banner .sunmmer-banner-btn{
    width: 100%;
    font-size: 12px;
    height: 68px;
    justify-content: flex-start;
    padding-left: 30px;
  }
  .sunmmer-banner .sunmmer-banner-t{
    font-size: 16px;
    font-family: var(--text-font-family);
  }
  .sunmmer-banner .sunmmer-banner-p{
    font-size: 12px;
  }
  .sunmmer-banner .sunmmer-banner-p span{
    font-size: 12px;
  }
  .sunmmer-banner .sunmmer-banner-btn .img{
    width: 33px;
  }
}
</style>

<section class="section-box">
  <div class="sunmmer-banner">
    {%- if section.settings.image != blank -%}
      <img loading="lazy" class="img pc-box" width="" height="" src="{{ section.settings.image | image_url }}">
    {%- endif -%}
    {%- if section.settings.image1 != blank -%}
      <img loading="lazy" class="img mb-box" width="" height="" src="{{ section.settings.image1 | image_url }}">
    {%- endif -%}
    <div class="sunmmer-banner-text">
      <div class="container">
        <div class="sunmmer-banner-text-left">
          {%- if section.settings.text != blank -%}
            <div class="sunmmer-banner-tag to-top">
              {{ section.settings.text }}
            </div>
          {%- endif -%}
          <div class="sunmmer-banner-title line-top" style="transition-delay: 0.1s">{{ section.settings.text1 }}</div>
          <div class="sunmmer-banner-sub line-top" style="transition-delay: 0.2s">{{ section.settings.text2 }}</div>
        </div>
        <div class="sunmmer-banner-text-right to-top" style="transition-delay: 0.3s">
          {%- if section.settings.text3 != blank -%}
            <div class="sunmmer-banner-btn" onclick="btnScrollToTop('{{ section.settings.text4 }}')">
              <div>
                <div class="sunmmer-banner-t">{{ section.settings.text3 }}</div>
                <div class="sunmmer-banner-p">
                  {{ section.settings.text5 }}
                  <span>{{ section.settings.text6 }}</span>
                </div>
              </div>
              {%- if section.settings.image2 != blank -%}
                <img loading="lazy" class="img" width="" height="" src="{{ section.settings.image2 | image_url }}">
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>
  <script>
      // 
    function btnScrollToTop(name) {
    let section = document.querySelector(name)
      section.scrollIntoView({ behavior: 'smooth' });
    }
  </script>                   
