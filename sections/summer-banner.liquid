      "label": "副标题"
    },
    {
      "type": "text",
      "id": "text3",
      "label": "按钮文字"
    },
    {
      "type": "image_picker",
      "id": "image2",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "text5",
      "label": "按钮文字"
    },
    {
      "type": "text",
      "id": "text6",
      "label": "按钮文字"
    },
    {
      "type": "text",
