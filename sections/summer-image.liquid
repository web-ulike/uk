<section class="section-box">
  <div class="comparison-image to-top {{ section.settings.text }}">
    {%- if section.settings.image != blank -%}
      <img loading="lazy" class="img pc-box" width="" height="" src="{{ section.settings.image | image_url }}">
    {%- endif -%}
    {%- if section.settings.image1 != blank -%}
      <img loading="lazy" class="img mb-box" width="" height="" src="{{ section.settings.image1 | image_url }}">
    {%- endif -%}
    {%- if section.settings.text4 != blank -%}
      <div class="comparison-image-btn comparison-image-btn-left {% if section.settings.text4 != blank %}show-popup-btn{% endif %}" data-name="{{ section.settings.text4 }}">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 28 28" fill="none">
          <g clip-path="url(#clip0_2226_3528)">
            <circle cx="14.0008" cy="14" r="13.2" fill="#6C6AB4"/>
