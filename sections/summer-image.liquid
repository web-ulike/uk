          </g>
          <defs>
            <clipPath id="clip0_2226_3528">
              <rect width="26.4" height="26.4" fill="white" transform="translate(0.800781 0.799988)"/>
            </clipPath>
          </defs>
        </svg>
      </div>
    {%- endif -%}
    {%- if section.settings.text5 != blank -%}
      <div class="comparison-image-btn comparison-image-btn-right {% if section.settings.text5 != blank %}show-popup-btn{% endif %}" data-name="{{ section.settings.text5 }}">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 28 28" fill="none">
          <g clip-path="url(#clip0_2226_3528)">
            <circle cx="14.0008" cy="14" r="13.2" fill="#6C6AB4"/>
            <path d="M20.887 13.5549H14.5731V7.24367C14.5731 6.92656 14.3127 6.66875 13.9982 6.66875C13.6811 6.66875 13.4233 6.92914 13.4233 7.24367V13.5549H7.11203C6.79492 13.5549 6.53711 13.8153 6.53711 14.1298C6.53711 14.447 6.7975 14.7048 7.11203 14.7048H13.4233V21.0186C13.4233 21.3357 13.6837 21.5935 13.9982 21.5935C14.3153 21.5935 14.5731 21.3331 14.5731 21.0186V14.7048H20.8844C21.2015 14.7048 21.4593 14.4444 21.4619 14.1298C21.4619 13.8127 21.2015 13.5549 20.887 13.5549Z" fill="white"/>
          </g>
          <defs>
            <clipPath id="clip0_2226_3528">
              <rect width="26.4" height="26.4" fill="white" transform="translate(0.800781 0.799988)"/>
            </clipPath>
          </defs>
        </svg>
      </div>
    {%- endif -%}
    <div class="comparison-image-cont to-top" style="transition-delay: 0.1s">
      <div class="container">
        <div class="comparison-image-sub">{{ section.settings.text2 }}</div>
        <div class="comparison-image-title">{{ section.settings.text1 }}</div>
        <div class="comparison-image-p">{{ section.settings.text3 }}</div>
      </div>
    </div>
  </div>

   <div class="result-new-popup result-new-popup-one">
    <div class="result-new-popup-mark"></div>
    <div class="result-new-popup-cont">
      <div class="result-new-popup-close">
        <svg xmlns="http://www.w3.org/2000/svg" width="23" height="23" viewBox="0 0 23 23" fill="none">
          <line x1="2.02941" y1="0.848633" x2="22.182" y2="21.0012" stroke="#3F3636" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="22.1836" y1="1.06066" x2="2.03105" y2="21.2132" stroke="#3F3636" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'popup1' -%}
        <div class="result-new-popup-det">
          <div class="result-new-popup-left">
            <div class="result-new-popup-sub">{{ block.settings.text }}</div>
          </div>
          <div class="result-new-popup-right">
            <div class="result-new-popup-title">{{ block.settings.text1 }}</div>
            <div class="result-new-popup-p">
              {{ block.settings.text2 }}
            </div>
            <div class="result-new-popup-video">
              {% if block.settings.img_2 != blank %}
                 <img src="{{ block.settings.img_2 | image_url }}" width="" height="" class="img-video" alt="{{ block.settings.img_2 | escape }}"/>
              {% endif %}
              {%- if block.settings.video != blank -%}
                <native-video {% if block.settings.autoplay %} autoplay{% endif %} class="product-video">
                  {%- unless block.settings.autoplay -%}
                    <button type="button" class="video-wrapper__play-button video-wrapper__play-button--large video-wrapper__play-button--ripple" title="{{ 'general.accessibility.play_video' | t | escape }}">
                      {%- if block.settings.v_icon != blank -%}
                        <img
                          loading="lazy"
                          class="v_img"
                          width="{{ block.settings.v_icon.width }}"
                          height="{{ block.settings.v_icon.height }}"
                          {% render 'image-attributes', image: block.settings.v_icon %}
                          alt="{{ block.settings.v_icon.alt | escape }}"
                        >
                      {%- endif -%}
                    </button>
                  {%- endunless -%}
                  <template>
                    {{-
                      block.settings.video
                      | video_tag:
                        controls: block.settings.show_video_controls,
                        autoplay: block.settings.autoplay,
                        muted: block.settings.autoplay,
                        playsinline: block.settings.autoplay,
                        loop: true
                    -}}
                  </template>
                </native-video>
              {%- endif -%}
            </div>
            <div class="result-new-popup-list">
              <div class="result-new-popup-item">
                <div class="result-new-popup-t">{{ block.settings.text3 }}</div>
                <div class="result-new-popup-d">{{ block.settings.text4 }}</div>
              </div>
              <div class="result-new-popup-item">
                <div class="result-new-popup-t">{{ block.settings.text5 }}</div>
                <div class="result-new-popup-d">{{ block.settings.text6 }}</div>
              </div>
            </div>
          </div>
        </div>
      {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
            
