<style>
.preheat-roster{
  padding: 80px 0;
}

.preheat-roster-cont{
  display: flex;
  align-items: center;
  gap: 12%;
}

.preheat-roster-left{
  width: 26.4%;
  color: #3F3636;
}

.preheat-roster-title{
  font-size: 50px;
  line-height: 1.2;
}

.preheat-roster-sub{
  font-size: 16px;
  line-height: 1.5;
  margin-top: 16px;
}

.preheat-roster-right{
  padding: 70px 5px;
  border-radius: 10px;
  background: #FBFAF4;
  flex: 1;
}

.preheat-roster-list{
  padding: 0 14.2%;
  max-height: 225px;
  overflow-y: auto;
}

.preheat-roster-list ul{
  display: flex;
  flex-wrap: wrap;
  gap: 27px;
  list-style: none;
  padding: 0;
}
.preheat-roster-list li{
  width: calc(33.333% - 18px);
  color: #000;
  font-size: 18px;
  line-height: 1.25;
  text-align: center;
}


.preheat-roster-list::-webkit-scrollbar {
    width: 8px; /* 设置滚动条宽度 */
}

.preheat-roster-list::-webkit-scrollbar-track {
    background: none; /* 设置滚动条背景色 */
}

.preheat-roster-list::-webkit-scrollbar-thumb {
    background: #E4DDDD; /* 设置滚动条滑块颜色 */
    border-radius: 5px; /* 设置滑块圆角 */
}

.preheat-roster-list::-webkit-scrollbar-thumb:hover {
    background: #E4DDDD; /* 设置滑块鼠标悬停时颜色 */
}

@media (max-width:1400px) {
  .preheat-roster-right{
    padding: 60px 0;
  }
  .preheat-roster-list{
    padding: 0 30px;
  }
  .preheat-roster-list li{
    font-size: 16px;
  }
}

@media (max-width:1200px) {
  .preheat-roster-title{
    font-size: 40px;
  }
}

@media (max-width:991px) {
  .preheat-roster{
    padding: 60px 0;
  }
  .preheat-roster-cont{
    flex-direction: column;
    gap: 32px;
  }
  .preheat-roster-left{
    width: 100%;
    text-align: center;
  }
  .preheat-roster-title{
    font-size: 24px;
  }
  .preheat-roster-sub{
    font-size: 14px;
  }
  .preheat-roster-right{
    padding: 30px 5px;
  }
  .preheat-roster-list{
    padding: 0 20px;
    max-height: 170px;
  }
  .preheat-roster-list ul{
    gap: 20px;
  }
  .preheat-roster-list li{
    font-size: 14px;
    width: calc(50% - 10px);
  }
  .preheat-roster-list::-webkit-scrollbar {
    width: 6px;
  }
}
</style>

<section class="section-box">
  <div class="preheat-roster">
    <div class="container">
      <div class="preheat-roster-cont">
        <div class="preheat-roster-left">
          <div class="preheat-roster-title line-top"> {{ section.settings.text }} </div>
          <div class="preheat-roster-sub line-top"> {{ section.settings.text1 }} </div>
        </div>
        <div class="preheat-roster-right to-top">
          <div class="preheat-roster-list">
            {{ section.settings.text2 }}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "preheat-roster",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "text1",
      "label": "Text"
    },
    {
      "type": "richtext",
      "id": "text2",
      "label": "Text"
    }
  ],
  "presets": [
    {
      "name": "preheat-roster"
    }
  ]
}
{% endschema %}