        "image5": "shopify:\/\/shop_images\/f7.png",
        "image6": "shopify:\/\/shop_images\/f8.png",
        "text4": "Normal Mode",
        "text5": "Ideal to remove finer to normal hair.",
        "image7": "shopify:\/\/shop_images\/f4_a9864812-94e8-48ab-ad19-40af1ae28d76.png",
        "image8": "shopify:\/\/shop_images\/f9.png",
        "image9": "shopify:\/\/shop_images\/f10.png",
        "text6": "Fast Mode",
        "text7": "Best for maintenance and small touch-ups.",
        "image10": "shopify:\/\/shop_images\/f14.png",
        "image11": "shopify:\/\/shop_images\/f11.png",
        "text8": "AutoGlide Mode",
        "text9": "Long press flash button to turn on. Under AutoGlide mode, device flashes up automatically.",
        "text10": "Switch into AutoGlide",
        "image12": "shopify:\/\/shop_images\/f12.png",
        "text11": "SHR Mode",
        "text12": "High-intensity treatment to eliminate stubborn hair",
        "image13": "shopify:\/\/shop_images\/f13.jpg",
        "text13": "AutoGlideMode",
